# Raíz del repo: copia a .env →  copy .env.example .env
#
# Docker Compose carga este archivo con `env_file` (la URL de la base no pasa por interpolación
# de Compose, así que contraseñas con `$` o `&` no se rompen).
#
# === OBLIGATORIO: Supabase (Postgres en la nube) ===
# Dashboard → Settings → Database → Connect → modo "Session pooler".
# Puedes pegar la URI tal cual (postgresql:// o postgres://); la API añade +asyncpg si falta.
# Codifica caracteres especiales de la contraseña en la URL (@ → %40, * → %2A) o usa la URI que ya trae el panel.
#
# Ejemplo (ref de proyecto wsp-agent-citas-2026 — sustituye la contraseña):
#   postgresql+asyncpg://postgres.suucemzarpccrvgttuev:TU_PASSWORD@aws-0.sa-east-1.pooler.supabase.com:6543/postgres
# Dashboard: https://supabase.com/dashboard/project/suucemzarpccrvgttuev/settings/database
#
# Si TLS falla (antivirus/proxy): DATABASE_SSL_VERIFY=false
DATABASE_URL=

INTERNAL_API_KEY=dev-internal-key
# Pepper para HMAC de claves en `workspace_api_keys` (cámbialo en producción).
INTERNAL_API_KEY_PEPPER=change-me-in-production

# Timeouts (segundos): LLM por llamada; pipeline completo del webhook Twilio (sync).
LLM_TIMEOUT_SECONDS=45
WEBHOOK_PROCESSING_TIMEOUT_SECONDS=25

# true + REDIS_URL + servicio `worker` (docker compose --profile worker): respuesta async vía REST Twilio.
WEBHOOK_ASYNC_REPLIES=false

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=false
WEBHOOK_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
CORS_ORIGINS=http://localhost:3000

# Panel Next (`npm run dev` en el host): crea `apps/web/.env.local` con BACKEND_URL=http://127.0.0.1:8000
# (el hostname `api` solo existe dentro de Docker). En Compose, el servicio `web` usa http://api:8000.

# Redis en Docker (rate limit / opcional). Vacío si corres la API fuera de Compose sin Redis.
REDIS_URL=redis://redis:6379/0
LOG_JSON=false
LOG_LEVEL=INFO
GIT_COMMIT=local
