# API (local con uvicorn). Con Docker Compose usa el .env de la raíz (misma DATABASE_URL).
#
# Supabase: Dashboard → Connect → Session pooler. Copia host y usuario postgres.<PROJECT_REF>.
# postgresql+asyncpg://postgres.<REF>:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# (host exacto en Connect; a veces aws-1-REGION...)
# Codifica caracteres especiales en la contraseña (* → %2A, @ → %40).
# Solo si TLS falla por antivirus/proxy: DATABASE_SSL_VERIFY=false
DATABASE_URL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=false
WEBHOOK_BASE_URL=https://tu-tunel.ngrok-free.app
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Calendar (opcional; también se puede guardar en el panel)
GOOGLE_CALENDAR_ID=
# JSON completo de cuenta de servicio en una sola línea o multilínea según tu .env
GOOGLE_SERVICE_ACCOUNT_JSON=

INTERNAL_API_KEY=dev-internal-key
CORS_ORIGINS=http://localhost:3000

# Opcional: rate limit del webhook con Redis (varias réplicas). Ej.: redis://localhost:6379/0
REDIS_URL=

# Logs: true = JSON por línea; nivel DEBUG|INFO|WARNING|ERROR
LOG_JSON=false
LOG_LEVEL=INFO

# Build / despliegue (visible en GET /internal/status y panel Estado)
GIT_COMMIT=

# --- SaaS: códigos de login/registro por WhatsApp (Twilio Verify del PROVEEDOR) ---
# Un solo Verify Service en la cuenta Twilio del hosting; sirve para todos los negocios que se registren.
TWILIO_VERIFY_SERVICE_SID=
# Opcional (solo despliegues sin registro público): si no hay ningún operador, crea un admin en el workspace por defecto.
PANEL_BOOTSTRAP_ADMIN_E164=
PANEL_BOOTSTRAP_ADMIN_NAME=Admin
PANEL_SESSION_DAYS=14
